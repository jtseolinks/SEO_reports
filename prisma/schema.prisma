generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

enum MembershipRole {
  OWNER
  ADMIN
  MEMBER
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum GoogleConnectionStatus {
  CONNECTED
  REQUIRES_REAUTH
  ERROR
}

enum KeywordMatchType {
  EXACT
  CONTAINS
}

enum ReportStatus {
  DRAFT
  GENERATED
  SENT
  FAILED
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

// ─── Tenancy ──────────────────────────────────────────────────────────────────

model Agency {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships      Membership[]
  invitations      Invitation[]
  clients          Client[]
  googleConnection GoogleConnection?
  settings         AgencySetting[]
  monthlyReports   MonthlyReport[]
  gscDailyData     GscDailyData[]
  ga4DailyData     Ga4DailyData[]
  reportEmailLogs  ReportEmailLog[]
  syncJobs         SyncJob[]
  setupTokens      SetupToken[]
}

model SetupToken {
  id             String    @id @default(cuid())
  tokenHash      String    @unique
  userId         String
  agencyId       String
  expiresAt      DateTime
  usedAt         DateTime?
  isAgencySetup  Boolean   @default(false)
  createdAt      DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agencyId])
}

model Membership {
  id        String         @id @default(cuid())
  userId    String
  agencyId  String
  role      MembershipRole @default(MEMBER)
  createdAt DateTime       @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([userId, agencyId])
  @@index([agencyId])
  @@index([userId])
}

model Invitation {
  id          String           @id @default(cuid())
  agencyId    String
  email       String
  role        MembershipRole   @default(MEMBER)
  tokenHash   String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  acceptedAt  DateTime?
  invitedById String?
  createdAt   DateTime         @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@unique([agencyId, email])
  @@index([agencyId])
  @@index([email])
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  name               String?
  passwordHash       String?
  role               UserRole     @default(ADMIN)
  isSuperAdmin       Boolean      @default(false)
  lastActiveAgencyId String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  memberships  Membership[]
  setupTokens  SetupToken[]
}

model GoogleConnection {
  id                    String                 @id @default(cuid())
  agencyId              String                 @unique
  googleEmail           String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  expiresAt             DateTime?
  scopes                String[]
  status                GoogleConnectionStatus @default(CONNECTED)
  lastError             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
}

model Client {
  id             String       @id @default(cuid())
  agencyId       String
  name           String
  domain         String
  contactEmail   String
  ccEmails       String[]     @default([])
  reportSendDay  Int          @default(5)
  reportSendHour Int          @default(9)   // hour of day (0-23, Asia/Jerusalem) for auto-send
  status         ClientStatus @default(ACTIVE)
  notes          String?
  industry       String?
  reportLanguage String       @default("he")
  autoSend       Boolean      @default(true)
  brandNameHe         String?
  brandNameEn         String?
  excludeFromReports  Boolean  @default(false)
  sendDayCustom       Boolean  @default(false)
  reportConfig        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  agency           Agency                @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  googleProperties ClientGoogleProperty?
  keywords         ClientKeyword[]
  gscDailyData     GscDailyData[]
  ga4DailyData     Ga4DailyData[]
  monthlyReports   MonthlyReport[]
  syncJobs         SyncJob[]

  @@index([agencyId])
  @@index([agencyId, status])
  @@index([domain])
}

model ClientGoogleProperty {
  id              String   @id @default(cuid())
  clientId        String   @unique
  gscSiteUrl      String
  ga4PropertyId   String
  ga4PropertyName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([gscSiteUrl])
  @@index([ga4PropertyId])
}

model ClientKeyword {
  id        String           @id @default(cuid())
  clientId  String
  keyword   String
  groupName String?
  isBrand   Boolean          @default(false)
  isActive  Boolean          @default(true)
  matchType KeywordMatchType @default(CONTAINS)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, keyword])
  @@index([clientId])
  @@index([keyword])
  @@index([isActive])
}

model GscDailyData {
  id          String   @id @default(cuid())
  agencyId    String
  clientId    String
  siteUrl     String
  date        DateTime
  query       String?
  page        String?
  country     String?
  device      String?
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
  @@index([clientId, query])
  @@index([clientId, page])
  @@index([agencyId, date])
  @@index([siteUrl])
}

model Ga4DailyData {
  id              String   @id @default(cuid())
  agencyId        String
  clientId        String
  propertyId      String
  date            DateTime
  landingPage     String?
  sourceMedium    String?
  channelGroup    String?
  sessions        Int      @default(0)
  activeUsers     Int      @default(0)
  engagedSessions Int      @default(0)
  engagementRate  Float    @default(0)
  conversions     Float    @default(0)
  totalRevenue    Float    @default(0)
  createdAt       DateTime @default(now())

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
  @@index([clientId, landingPage])
  @@index([agencyId, date])
  @@index([propertyId])
  @@index([channelGroup])
}

model MonthlyReport {
  id              String       @id @default(cuid())
  agencyId        String
  clientId        String
  reportMonth     String
  periodStart     DateTime
  periodEnd       DateTime
  comparisonStart DateTime
  comparisonEnd   DateTime
  pdfUrl          String?
  status          ReportStatus @default(DRAFT)
  generatedAt     DateTime?
  sentAt          DateTime?
  emailTo         String?
  emailCc         String[]     @default([])
  errorMessage    String?
  gscClicks       Int          @default(0)
  gscImpressions  Int          @default(0)
  gscPosition     Float        @default(0)
  gscCtr          Float        @default(0)
  openCount       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  agency    Agency           @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  emailLogs ReportEmailLog[]

  @@unique([clientId, reportMonth])
  @@index([clientId, reportMonth])
  @@index([agencyId, status])
  @@index([status])
}

model ReportEmailLog {
  id                String    @id @default(cuid())
  agencyId          String
  reportId          String
  clientId          String
  emailTo           String
  emailCc           String[]  @default([])
  subject           String
  status            String
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  agency Agency        @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  report MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([clientId])
  @@index([agencyId, status])
  @@index([status])
}

model AgencySetting {
  agencyId  String
  key       String
  value     String
  updatedAt DateTime @updatedAt

  agency Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  @@id([agencyId, key])
}

// Platform-wide settings (single source of truth, not tenant-scoped). Holds the
// shared SMTP transport (host/port/user/pass + sender identity) used for ALL
// outgoing mail. Managed only by super-admins. Secrets (smtpPass) are encrypted
// at rest with the same scheme as AgencySetting.
model PlatformSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model SyncJob {
  id           String        @id @default(cuid())
  agencyId     String
  clientId     String?
  jobType      String
  dateFrom     DateTime?
  dateTo       DateTime?
  status       SyncJobStatus @default(PENDING)
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  createdAt    DateTime      @default(now())

  agency Agency  @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([agencyId, status])
  @@index([clientId])
  @@index([status])
  @@index([jobType])
}
