generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
}

enum ClientStatus {
  ACTIVE
  INACTIVE
}

enum GoogleConnectionStatus {
  CONNECTED
  REQUIRES_REAUTH
  ERROR
}

enum KeywordMatchType {
  EXACT
  CONTAINS
}

enum ReportStatus {
  DRAFT
  GENERATED
  SENT
  FAILED
}

enum SyncJobStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String?
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model GoogleConnection {
  id                    String                 @id @default(cuid())
  googleEmail           String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  expiresAt             DateTime?
  scopes                String[]
  status                GoogleConnectionStatus @default(CONNECTED)
  lastError             String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
}

model Client {
  id             String       @id @default(cuid())
  name           String
  domain         String
  contactEmail   String
  ccEmails       String[]     @default([])
  reportSendDay  Int          @default(5)
  status         ClientStatus @default(ACTIVE)
  notes          String?
  industry       String?
  reportLanguage String       @default("he")
  autoSend       Boolean      @default(true)
  brandNameHe         String?
  brandNameEn         String?
  excludeFromReports  Boolean  @default(false)
  sendDayCustom       Boolean  @default(false)
  reportConfig        Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  googleProperties ClientGoogleProperty?
  keywords         ClientKeyword[]
  gscDailyData     GscDailyData[]
  ga4DailyData     Ga4DailyData[]
  monthlyReports   MonthlyReport[]
  syncJobs         SyncJob[]

  @@index([status])
  @@index([domain])
}

model ClientGoogleProperty {
  id              String   @id @default(cuid())
  clientId        String   @unique
  gscSiteUrl      String
  ga4PropertyId   String
  ga4PropertyName String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([gscSiteUrl])
  @@index([ga4PropertyId])
}

model ClientKeyword {
  id        String           @id @default(cuid())
  clientId  String
  keyword   String
  groupName String?
  isBrand   Boolean          @default(false)
  isActive  Boolean          @default(true)
  matchType KeywordMatchType @default(CONTAINS)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, keyword])
  @@index([clientId])
  @@index([keyword])
  @@index([isActive])
}

model GscDailyData {
  id          String   @id @default(cuid())
  clientId    String
  siteUrl     String
  date        DateTime
  query       String?
  page        String?
  country     String?
  device      String?
  clicks      Int      @default(0)
  impressions Int      @default(0)
  ctr         Float    @default(0)
  position    Float    @default(0)
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
  @@index([clientId, query])
  @@index([clientId, page])
  @@index([siteUrl])
}

model Ga4DailyData {
  id              String   @id @default(cuid())
  clientId        String
  propertyId      String
  date            DateTime
  landingPage     String?
  sourceMedium    String?
  channelGroup    String?
  sessions        Int      @default(0)
  activeUsers     Int      @default(0)
  engagedSessions Int      @default(0)
  engagementRate  Float    @default(0)
  conversions     Float    @default(0)
  totalRevenue    Float    @default(0)
  createdAt       DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, date])
  @@index([clientId, landingPage])
  @@index([propertyId])
  @@index([channelGroup])
}

model MonthlyReport {
  id              String       @id @default(cuid())
  clientId        String
  reportMonth     String
  periodStart     DateTime
  periodEnd       DateTime
  comparisonStart DateTime
  comparisonEnd   DateTime
  pdfUrl          String?
  status          ReportStatus @default(DRAFT)
  generatedAt     DateTime?
  sentAt          DateTime?
  emailTo         String?
  emailCc         String[]     @default([])
  errorMessage    String?
  gscClicks       Int          @default(0)
  gscImpressions  Int          @default(0)
  gscPosition     Float        @default(0)
  gscCtr          Float        @default(0)
  openCount       Int          @default(0)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  emailLogs ReportEmailLog[]

  @@unique([clientId, reportMonth])
  @@index([clientId, reportMonth])
  @@index([status])
}

model ReportEmailLog {
  id                String    @id @default(cuid())
  reportId          String
  clientId          String
  emailTo           String
  emailCc           String[]  @default([])
  subject           String
  status            String
  providerMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime  @default(now())

  report MonthlyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([clientId])
  @@index([status])
}

model AgencySetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model SyncJob {
  id           String        @id @default(cuid())
  clientId     String?
  jobType      String
  dateFrom     DateTime?
  dateTo       DateTime?
  status       SyncJobStatus @default(PENDING)
  startedAt    DateTime?
  finishedAt   DateTime?
  errorMessage String?
  createdAt    DateTime      @default(now())

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([status])
  @@index([jobType])
}
